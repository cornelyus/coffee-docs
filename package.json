{
  "name": "specialty_coffee_docs_site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:velite dev:next",
    "dev:velite": "velite --watch",
    "dev:next": "next dev",
    "build": "velite build && next build",
    "postbuild": "tsx scripts/index-docs.ts",
    "start": "next start",
    "lint": "eslint",
    "index-docs": "dotenv -e .env.local -- tsx scripts/index-docs.ts"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.2",
    "@supabase/supabase-js": "^2.103.0",
    "@tailwindcss/typography": "^0.5.0-alpha.3",
    "@vercel/analytics": "^2.0.1",
    "negotiator": "^1.0.0",
    "next": "^16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
